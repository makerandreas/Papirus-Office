# Explicitly declare binary files to prevent Git from corrupting them via line-ending conversions
*.jar binary
*.png binary
*.gif binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.jks binary
*.keystore binary

# Ensure shell scripts and Gradle wrappers always use LF (Unix) line endings
gradlew text eol=lf
*.sh text eol=lf

# Ensure Windows batch files always use CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf
