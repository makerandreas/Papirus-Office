    <!-- Help Dialog Strings -->
    <string name="help_dialog_main_title">Papirus Office Options Help</string>
    <string name="help_dialog_main_body">Configure system preferences, user data, load and save rules, locale settings, and module options for Papirus Office. Settings applied here are saved automatically across all document editors.</string>
    <string name="help_dialog_load_save_title">Help: Load and Save - General</string>
    <string name="help_dialog_load_save_body">Configure document loading preferences (user settings, printer configuration) and saving defaults (Auto Recovery, backup copies, relative URLs, and default ODF/OOXML file formats).</string>
    <string name="help_dialog_auto_recovery_title">Help: Save Auto Recovery Options</string>
    <string name="help_dialog_auto_recovery_body">Auto Recovery saves critical recovery information periodically to protect open documents against system or app crashes. You can set the interval in minutes and optionally allow Papirus Office to automatically save the document itself.</string>
    <string name="help_dialog_backup_copy_title">Help: Always Create a Backup Copy</string>
    <string name="help_dialog_backup_copy_body">Saves the previous version of a document as a BAK backup copy whenever you save. The backup is stored in the default backups directory or in the same folder as the document if enabled.</string>

